# Public Supabase config
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only Supabase config
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Upstash Redis / Ratelimit
# Nota: la implementacion actual inicializa Redis.fromEnv() al cargar el modulo,
# por lo que estas variables deben existir aunque uses RATE_LIMIT_MODE=fallback u off.
UPSTASH_REDIS_REST_URL="https://your-upstash-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# Rate limit mode: upstash | fallback | off
RATE_LIMIT_MODE="upstash"

# Booking confirmation token signing
# Debe tener al menos 32 caracteres.
BOOKING_TOKEN_SECRET="replace-with-a-long-random-secret"

# Opcional. La app acota el valor entre 24 y 48 horas.
BOOKING_TOKEN_EXPIRATION_HOURS="24"
